{
    "name": "hive-indexer",
    "private": true,
    "scripts": {
        "build": "rm -rf lib && tsc",
        "db:migrate": "squid-typeorm-migration apply",
        "processor:start": "node lib/main",
        "query-node:start": "squid-graphql-server",
        "gen:abi": "squid-evm-typegen src/abi abi/AuditBountyEscrow.json",
        "gen:model": "squid-typeorm-codegen",
        "codegen": "npm run gen:abi && npm run gen:model",
        "start": "npm run processor:start",
        "up": "docker compose up -d"
    },
    "dependencies": {
        "@subsquid/archive-registry": "*",
        "@subsquid/big-decimal": "*",
        "@subsquid/evm-processor": "*",
        "@subsquid/graphql-server": "*",
        "@subsquid/typeorm-migration": "*",
        "@subsquid/typeorm-store": "*",
        "dotenv": "*",
        "pg": "*",
        "typeorm": "*",
        "ethers": "*"
    },
    "devDependencies": {
        "@subsquid/cli": "*",
        "@subsquid/evm-typegen": "*",
        "@subsquid/typeorm-codegen": "*",
        "@types/node": "*",
        "typescript": "*"
    }
}